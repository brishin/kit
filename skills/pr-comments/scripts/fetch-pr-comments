#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

"""
Fetch review summaries and inline comments from a GitHub PR in a single
GraphQL call.
"""

import json
import subprocess
import sys
from typing import Any

GRAPHQL_QUERY = """
query($owner: String!, $repo: String!, $number: Int!) {
  repository(owner: $owner, name: $repo) {
    pullRequest(number: $number) {
      reviews(first: 100) {
        nodes {
          state
          submittedAt
          author { login }
          body
          comments(first: 100) {
            nodes {
              path
              line
              originalLine
              author { login }
              body
            }
          }
        }
      }
    }
  }
}
"""


def resolve_repo(repo_arg: str | None) -> tuple[str, str]:
    if repo_arg:
        owner, _, name = repo_arg.partition("/")
        if not owner or not name:
            print(f"Invalid repo '{repo_arg}', expected OWNER/REPO", file=sys.stderr)
            sys.exit(1)
        return owner, name

    result = subprocess.run(
        ["gh", "repo", "view", "--json", "owner,name"],
        capture_output=True,
        text=True,
        check=True,
    )
    data = json.loads(result.stdout)
    return data["owner"]["login"], data["name"]


def fetch_pr_data(owner: str, repo: str, pr_number: str) -> dict[str, Any]:
    result = subprocess.run(
        [
            "gh",
            "api",
            "graphql",
            "-f",
            f"query={GRAPHQL_QUERY}",
            "-F",
            f"owner={owner}",
            "-F",
            f"repo={repo}",
            "-F",
            f"number={pr_number}",
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    payload = json.loads(result.stdout)
    return payload["data"]["repository"]["pullRequest"]


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: fetch-pr-comments <PR_NUMBER> [OWNER/REPO]", file=sys.stderr)
        sys.exit(1)

    pr_number = sys.argv[1]
    repo_arg = sys.argv[2] if len(sys.argv) > 2 else None

    try:
        owner, repo = resolve_repo(repo_arg)
        pr = fetch_pr_data(owner, repo, pr_number)
    except subprocess.CalledProcessError as e:
        print(f"Error calling gh: {e.stderr}", file=sys.stderr)
        sys.exit(1)
    except (KeyError, json.JSONDecodeError) as e:
        print(f"Error parsing gh response: {e}", file=sys.stderr)
        sys.exit(1)

    review_nodes = pr.get("reviews", {}).get("nodes", []) or []

    summaries = []
    inline = []
    for review in review_nodes:
        author = (review.get("author") or {}).get("login", "")
        body = (review.get("body") or "").strip()
        if body:
            summaries.append(
                {
                    "state": review.get("state", ""),
                    "submitted_at": review.get("submittedAt", ""),
                    "author": author,
                    "body": body,
                }
            )
        for comment in (review.get("comments") or {}).get("nodes", []) or []:
            inline.append(
                {
                    "path": comment.get("path", ""),
                    "line": comment.get("line") or comment.get("originalLine"),
                    "author": (comment.get("author") or {}).get("login", ""),
                    "body": comment.get("body", ""),
                }
            )

    print("=== REVIEW SUMMARIES ===")
    if summaries:
        for s in summaries:
            print(json.dumps(s, indent=2))
    else:
        print("No review summaries found.")

    print("\n=== INLINE REVIEW COMMENTS ===")
    if inline:
        for c in inline:
            print(json.dumps(c, indent=2))
    else:
        print("No inline comments found.")


if __name__ == "__main__":
    main()
