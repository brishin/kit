#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

"""
Fetch review summaries and inline comments from a GitHub PR in a single
GraphQL call.

Usage:
  fetch-pr-comments <PR_NUMBER> [OWNER/REPO] [flags]

Flags:
  --author <login>     Only show comments authored by <login>. Repeatable.
                       Comparison is case-insensitive.
  --exclude-bots       Skip comments from common review bots (cursor,
                       devin-ai-integration, github-actions[bot], coderabbitai,
                       copilot-pull-request-reviewer[bot], etc.).
"""

import argparse
import json
import subprocess
import sys
from typing import Any

KNOWN_BOTS = {
    "cursor",
    "devin-ai-integration",
    "github-actions",
    "github-actions[bot]",
    "coderabbitai",
    "coderabbitai[bot]",
    "copilot-pull-request-reviewer",
    "copilot-pull-request-reviewer[bot]",
    "sentry-io",
    "sentry-io[bot]",
}

GRAPHQL_QUERY = """
query($owner: String!, $repo: String!, $number: Int!) {
  repository(owner: $owner, name: $repo) {
    pullRequest(number: $number) {
      reviews(first: 100) {
        nodes {
          state
          submittedAt
          author { login }
          body
          comments(first: 100) {
            nodes {
              path
              line
              originalLine
              author { login }
              body
            }
          }
        }
      }
    }
  }
}
"""


def resolve_repo(repo_arg: str | None) -> tuple[str, str]:
    if repo_arg:
        owner, _, name = repo_arg.partition("/")
        if not owner or not name:
            print(f"Invalid repo '{repo_arg}', expected OWNER/REPO", file=sys.stderr)
            sys.exit(1)
        return owner, name

    result = subprocess.run(
        ["gh", "repo", "view", "--json", "owner,name"],
        capture_output=True,
        text=True,
        check=True,
    )
    data = json.loads(result.stdout)
    return data["owner"]["login"], data["name"]


def fetch_pr_data(owner: str, repo: str, pr_number: str) -> dict[str, Any]:
    result = subprocess.run(
        [
            "gh",
            "api",
            "graphql",
            "-f",
            f"query={GRAPHQL_QUERY}",
            "-F",
            f"owner={owner}",
            "-F",
            f"repo={repo}",
            "-F",
            f"number={pr_number}",
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    payload = json.loads(result.stdout)
    return payload["data"]["repository"]["pullRequest"]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="fetch-pr-comments",
        description="Fetch review summaries and inline comments from a GitHub PR.",
    )
    parser.add_argument("pr_number", help="PR number")
    parser.add_argument("repo", nargs="?", help="OWNER/REPO (defaults to current repo)")
    parser.add_argument(
        "--author",
        action="append",
        default=[],
        metavar="LOGIN",
        help="Only include comments by LOGIN (repeatable, case-insensitive).",
    )
    parser.add_argument(
        "--exclude-bots",
        action="store_true",
        help="Skip comments from common review bots.",
    )
    return parser.parse_args()


def keep(author: str, allowed_authors: set[str], exclude_bots: bool) -> bool:
    login = (author or "").lower()
    if allowed_authors and login not in allowed_authors:
        return False
    if exclude_bots and login in KNOWN_BOTS:
        return False
    return True


def main() -> None:
    args = parse_args()
    allowed_authors = {a.lower() for a in args.author}

    try:
        owner, repo = resolve_repo(args.repo)
        pr = fetch_pr_data(owner, repo, args.pr_number)
    except subprocess.CalledProcessError as e:
        print(f"Error calling gh: {e.stderr}", file=sys.stderr)
        sys.exit(1)
    except (KeyError, json.JSONDecodeError) as e:
        print(f"Error parsing gh response: {e}", file=sys.stderr)
        sys.exit(1)

    review_nodes = pr.get("reviews", {}).get("nodes", []) or []

    summaries = []
    inline = []
    for review in review_nodes:
        author = (review.get("author") or {}).get("login", "")
        body = (review.get("body") or "").strip()
        if body and keep(author, allowed_authors, args.exclude_bots):
            summaries.append(
                {
                    "state": review.get("state", ""),
                    "submitted_at": review.get("submittedAt", ""),
                    "author": author,
                    "body": body,
                }
            )
        for comment in (review.get("comments") or {}).get("nodes", []) or []:
            comment_author = (comment.get("author") or {}).get("login", "")
            if not keep(comment_author, allowed_authors, args.exclude_bots):
                continue
            inline.append(
                {
                    "path": comment.get("path", ""),
                    "line": comment.get("line") or comment.get("originalLine"),
                    "author": comment_author,
                    "body": comment.get("body", ""),
                }
            )

    filter_note = ""
    if allowed_authors:
        filter_note += f" (author={','.join(sorted(allowed_authors))})"
    if args.exclude_bots:
        filter_note += " (bots excluded)"

    print(f"=== REVIEW SUMMARIES{filter_note} ===")
    if summaries:
        for s in summaries:
            print(json.dumps(s, indent=2))
    else:
        print("No review summaries found.")

    print(f"\n=== INLINE REVIEW COMMENTS{filter_note} ===")
    if inline:
        for c in inline:
            print(json.dumps(c, indent=2))
    else:
        print("No inline comments found.")


if __name__ == "__main__":
    main()
