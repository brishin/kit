+function lineContainsInlineImage(line: string): boolean {
+	return line.includes("\x1b_G") || line.includes("\x1b]1337;File=");
+}
+
+function normalizeInlineImageCursorReservation(lines: string[]): string[] {
+	const imageLineIndex = lines.findIndex(lineContainsInlineImage);
+	if (imageLineIndex === -1 || lines.length <= 1) return lines;
+
+	const rowsBelowImageLine = lines.length - 1 - imageLineIndex;
+	if (rowsBelowImageLine <= 0) return lines;
+
+	// Newer Kitty rendering emits the image sequence first followed by blank
+	// reservation rows. @vanillagreen/pi-tool-renderer trims outer blank lines,
+	// which discards those trailing rows. Keep the image sequence in place (so
+	// the terminal still sees a plain graphics escape) and replace the blank
+	// reservation rows with a zero-width cursor-position escape that pi-tui's
+	// wrapping code understands. @vanillagreen's blank-line trimmer does not
+	// strip CSI-G, so the rows survive without being rendered as visible text.
+	const patched = [...lines];
+	for (let i = imageLineIndex + 1; i < patched.length; i++) {
+		if (patched[i] === "") patched[i] = "\x1b[1G";
+	}
+	return patched;
+}
