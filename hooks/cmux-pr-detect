#!/usr/bin/env bash
# PostToolUse hook: detect `gh pr create` output and report the new PR to cmux.
# Reads the Claude Code PostToolUse JSON payload from stdin.
# Fire-and-forget — all errors are silently swallowed so this never blocks.

set -euo pipefail

# --- Shared status helpers ---
# In test mode, print to console AND set cmux status (if available).
# In normal mode, only set cmux status.
TEST_MODE=false
HAS_CMUX=false
if command -v cmux >/dev/null 2>&1 && [[ -n "${CMUX_WORKSPACE_ID:-}" ]]; then
    HAS_CMUX=true
fi

set_status() {
    local key="$1" label="$2" icon="$3" color="$4"
    if $TEST_MODE; then
        echo "$label"
    fi
    if $HAS_CMUX; then
        cmux set-status "$key" "$label" --icon "$icon" --color "$color" 2>/dev/null || true
    fi
}

clear_status() {
    local key="$1"
    if $HAS_CMUX; then
        cmux clear-status "$key" 2>/dev/null || true
    fi
}

# Extract repo and pr_number from a GitHub PR URL. Sets global vars.
parse_pr_url() {
    pr_number="${pr_url##*/}"
    repo="${pr_url#https://github.com/}"
    repo="${repo%/pull/*}"
}

# --- Resolve Devin Review status (synchronous, single check) ---
resolve_devin_status() {
    local repo="$1" pr_number="$2"

    local sha
    sha=$(gh api "repos/${repo}/pulls/${pr_number}" --jq '.head.sha' 2>/dev/null) || return 1
    [[ -n "$sha" ]] || return 1

    local status_json
    status_json=$(gh api "repos/${repo}/commits/${sha}/statuses" 2>/dev/null) || return 1

    local devin_state
    devin_state=$(printf '%s' "$status_json" | jq -r '[.[] | select(.context == "Devin Review")][0].state // empty')

    if [[ -z "$devin_state" ]]; then
        set_status devin "Devin: No status found" "questionmark.circle" "#8B8B8B"
        return 0
    elif [[ "$devin_state" == "pending" ]]; then
        return 1  # Not done yet.
    elif [[ "$devin_state" == "success" ]]; then
        local reviews
        reviews=$(gh api "repos/${repo}/pulls/${pr_number}/reviews" 2>/dev/null) || reviews="[]"

        # Match Devin bot by login, falling back to body content.
        local devin_body
        devin_body=$(printf '%s' "$reviews" | jq -r '
            ([.[] | select(.user.login == "devin-ai-integration[bot]" or .user.login == "devin-ai[bot]")][0].body // empty)
            | if . == "" then null else . end
            // ([.[] | select(.body | test("Devin|devin"))][0].body // empty)
        ')

        local issue_count
        if printf '%s' "$devin_body" | grep -qi "No Issues Found"; then
            set_status devin "Devin: No issues" "checkmark.circle.fill" "#30A14E"
        elif issue_count=$(printf '%s' "$devin_body" | grep -oiE 'found ([0-9]+) potential issue' | grep -oE '[0-9]+' | head -1) && [[ -n "$issue_count" ]]; then
            set_status devin "Devin: ${issue_count} issue(s)" "exclamationmark.triangle.fill" "#E3B341"
        else
            set_status devin "Devin: Done" "checkmark.circle.fill" "#30A14E"
        fi
        return 0
    elif [[ "$devin_state" == "failure" || "$devin_state" == "error" ]]; then
        set_status devin "Devin: Failed" "xmark.circle.fill" "#F85149"
        return 0
    fi

    return 1  # Unknown state, keep polling.
}

# --- Resolve CI Checks status (synchronous, single check) ---
resolve_ci_status() {
    local repo="$1" pr_number="$2"

    local checks_json
    checks_json=$(gh pr checks "$pr_number" --repo "$repo" --json bucket,name 2>/dev/null) || return 1

    # Parse all counts in a single jq invocation.
    local counts
    counts=$(printf '%s' "$checks_json" | jq -r '[length, ([.[]|select(.bucket=="pending")]|length), ([.[]|select(.bucket=="fail")]|length), ([.[]|select(.bucket=="cancel")]|length)] | join(" ")')
    local total pending failed cancelled
    read -r total pending failed cancelled <<< "$counts"

    if [[ "$total" == "0" ]]; then
        clear_status ci
        if $TEST_MODE; then echo "CI: No checks"; fi
        return 0
    fi

    [[ "$pending" == "0" ]] || return 1

    if [[ "$failed" != "0" ]]; then
        set_status ci "CI: ${failed} failed" "xmark.circle.fill" "#F85149"
    elif [[ "$cancelled" != "0" ]]; then
        set_status ci "CI: Cancelled" "xmark.circle" "#8B8B8B"
    else
        set_status ci "CI: Passed" "checkmark.circle.fill" "#30A14E"
    fi
    return 0
}

# --- Generic polling loop: poll a resolve function with backoff ---
poll_until_resolved() {
    local resolve_fn="$1" key="$2" label="$3" repo="$4" pr_number="$5"
    set +e  # Don't let uncaught failures kill the poller silently.

    # Phase 1 (0-8min): poll every 30s, 16 checks
    for _ in $(seq 1 16); do
        sleep 30
        "$resolve_fn" "$repo" "$pr_number" && exit 0
    done

    # Phase 2 (8-15min): poll every 60s, 7 checks
    for _ in $(seq 1 7); do
        sleep 60
        "$resolve_fn" "$repo" "$pr_number" && exit 0
    done

    # Timed out.
    set_status "$key" "${label}: Timed out" "questionmark.circle" "#8B8B8B"
}

# --- Test mode: resolve status immediately and exit ---
if [[ "${1:-}" == "--test" ]]; then
    TEST_MODE=true
    if [[ -n "${2:-}" ]]; then
        pr_url="$2"
    else
        pr_url=$(gh pr view --json url --jq '.url' 2>/dev/null) || { echo "No PR found for current branch" >&2; exit 1; }
    fi
    parse_pr_url

    echo "Testing with PR: $pr_url"
    echo ""

    # Resolve both in parallel.
    (resolve_devin_status "$repo" "$pr_number" || echo "Devin: Pending...") &
    (resolve_ci_status "$repo" "$pr_number" || echo "CI: Pending...") &
    wait
    exit 0
fi

# --- Normal mode: PostToolUse hook ---
# Must be running inside a cmux terminal with a live socket.
[[ -S "${CMUX_SOCKET_PATH:-}" ]] || exit 0
[[ -n "${CMUX_TAB_ID:-}" ]] || exit 0
[[ -n "${CMUX_PANEL_ID:-}" ]] || exit 0

payload=$(cat)

# Only care about Bash tool invocations that ran `gh pr create`.
command_str=$(printf '%s' "$payload" | jq -r '.tool_input.command // empty')
[[ "$command_str" == *"gh pr create"* ]] || exit 0

# Extract the PR URL from tool output.
output=$(printf '%s' "$payload" | jq -r '.tool_output // empty')
pr_url=$(printf '%s' "$output" | grep -oE 'https://github\.com/[^/]+/[^/]+/pull/[0-9]+' | head -1)
[[ -n "$pr_url" ]] || exit 0
parse_pr_url

# Send report_pr to the cmux socket (same transport priority as shell integration).
msg="report_pr $pr_number $pr_url --state=open --tab=$CMUX_TAB_ID --panel=$CMUX_PANEL_ID"

if command -v ncat >/dev/null 2>&1; then
    printf '%s\n' "$msg" | ncat -w 1 -U "$CMUX_SOCKET_PATH" --send-only
elif command -v socat >/dev/null 2>&1; then
    printf '%s\n' "$msg" | socat -T 1 - "UNIX-CONNECT:$CMUX_SOCKET_PATH"
elif command -v nc >/dev/null 2>&1; then
    printf '%s\n' "$msg" | nc -w 1 -U "$CMUX_SOCKET_PATH"
fi

# --- Background status polling ---
if $HAS_CMUX; then
    # Set initial statuses.
    set_status devin "Devin: Reviewing..." "eye" "#E3B341"
    set_status ci "CI: Running..." "hammer" "#E3B341"

    ( poll_until_resolved resolve_devin_status devin "Devin" "$repo" "$pr_number" ) &>/dev/null &
    disown
    ( poll_until_resolved resolve_ci_status ci "CI" "$repo" "$pr_number" ) &>/dev/null &
    disown
fi

exit 0
